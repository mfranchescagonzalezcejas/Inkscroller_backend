# ===========================================================
# Inkscroller Backend — environment variable reference
# ===========================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# -- Core ----------------------------------------------------
DEBUG=false
CORS_ORIGINS=*

# -- Upstream APIs --------------------------------------------
MANGADEX_BASE_URL=https://api.mangadex.org
JIKAN_BASE_URL=https://api.jikan.moe/v4
CACHE_TTL_SECONDS=300

# -- Phase 5: Firebase Auth -----------------------------------
# Your Firebase project ID (from Firebase Console ? Project settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Path to the Firebase service-account JSON key file.
# Download from Firebase Console ? Project settings ? Service accounts.
# Leave empty when running against the Firebase emulator or when using
# Application Default Credentials in a GCP-hosted environment.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# -- Phase 5: SQLite persistence ------------------------------
# Relative or absolute path for the SQLite database file.
DB_PATH=./inkscroller.db
