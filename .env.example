# ===========================================================
# Inkscroller Backend — environment variable reference
# ===========================================================
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in the values below.
# 3. NEVER commit .env to version control.
#
# CI/CD: See SECURITY_PUBLIC_READINESS.md for how to inject
# these values via GitHub Secrets in automated pipelines.
# ===========================================================

# -- Core ----------------------------------------------------
# ENVIRONMENT controls production-like safety checks together with Railway runtime
# env vars. Any value production/prod/staging/stage from ENVIRONMENT,
# RAILWAY_ENVIRONMENT_NAME, or RAILWAY_ENVIRONMENT enables production-like checks.
# Local default is development.
ENVIRONMENT=development
DEBUG=false
# CORS_ORIGINS: comma-separated list of allowed frontend caller origins.
# Production-like environments must use explicit trusted origins; blank values and
# wildcard CORS are rejected when credentials are enabled.
# Note: CORS_ORIGINS contains caller origins, not API base URLs.
# Frontend clients should use the environment-specific API base URL:
#   dev:     https://api.dev.inkscroller.devdigi.dev
#   staging: https://api.stg.inkscroller.devdigi.dev  # reserved; verify after staging deploy/routing
#   prod:    https://api.inkscroller.devdigi.dev
# Local development may opt into permissive CORS explicitly with CORS_ORIGINS=*.
CORS_ORIGINS=https://inkscroller-app.web.app,https://devdigi.dev,https://www.devdigi.dev

# -- Upstream APIs --------------------------------------------
MANGADEX_BASE_URL=https://api.mangadex.org
JIKAN_BASE_URL=https://api.jikan.moe/v4
# Enable Jikan enrichment for manga details (default: true)
ENABLE_JIKAN_ENRICHMENT=true
# In-memory cache TTL in seconds (default: 5 minutes)
CACHE_TTL_SECONDS=300

# -- Firebase Auth --------------------------------------------
# Your Firebase project ID (from Firebase Console → Project settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Railway recommended: base64-encoded Firebase service-account JSON.
# Example:
#   base64 -w 0 serviceAccountKey.json              # Linux
#   base64 serviceAccountKey.json | tr -d '\n'      # macOS
#
# If set, the backend initializes Firebase Admin from this secret first.
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# Path to the Firebase service-account JSON key file.
# Download from Firebase Console → Project settings → Service accounts.
#
# LOCAL DEVELOPMENT: set this to the path of your downloaded key file.
# For the Flutter `dev` flavor, use the dev service-account key, for example:
#   GOOGLE_APPLICATION_CREDENTIALS=C:\Users\<you>\.ssh\firebase-dev-service-account.json
# CI: prefer FIREBASE_SERVICE_ACCOUNT_JSON_BASE64 for ephemeral runners.
# RAILWAY: prefer FIREBASE_SERVICE_ACCOUNT_JSON_BASE64 instead of a file path.
#
# NEVER commit the actual key file to version control.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# -- Database -------------------------------------------------
# Preferred for Railway / remote environments.
DATABASE_URL=

# SQLite persistence (local fallback)
# Relative or absolute path for the SQLite database file.
# In production, use PostgreSQL via DATABASE_URL for persistence.
DB_PATH=./inkscroller.db
